# ── Parcel Scout — Git Ignore ─────────────────────────────────────────────────

# Scan output files (timestamped exports — regenerated by the app)
results_*.csv
results_*.json
ranked_*.csv
ranked_*.json

# Streamlit secrets (never commit API keys)
.streamlit/secrets.toml

# Claude Code local config (machine-specific)
.claude/

# Python bytecode cache
__pycache__/
*.py[cod]
*.pyo
.Python

# Virtual environments
venv/
.venv/
env/

# macOS metadata
.DS_Store
